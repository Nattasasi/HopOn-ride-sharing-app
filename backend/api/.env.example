# Core runtime
PORT=3001
MONGO_URI=mongodb://localhost:27017/carpool
JWT_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
PASSWORD_RESET_TOKEN_EXPIRY_MS=900000

# CORS allowlist (comma-separated). In production, this should be explicit.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# HTTP rate limiting
API_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=25
BOOKING_MUTATION_RATE_LIMIT_MAX=120
BOOKING_REQUEST_SLA_MINUTES=10
# Minutes after booking creation during which a passenger can cancel for free
FREE_CANCEL_WINDOW_MINUTES=15

# Socket event throttling (per socket ID, per minute)
SOCKET_JOIN_RATE_LIMIT_MAX=30
SOCKET_SEND_RATE_LIMIT_MAX=120

# Optional app-specific keys
GOOGLE_MAPS_API_KEY=replace_with_google_maps_key
FCM_SERVICE_ACCOUNT=replace_with_fcm_service_account_json
