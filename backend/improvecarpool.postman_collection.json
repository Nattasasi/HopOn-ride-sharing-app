				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "BASE_URL",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "JWT_TOKEN",
			"value": "",
			"type": "string"
		},
		{
			"key": "POST_ID",
			"value": "",
			"type": "string"
		},
		{
			"key": "BOOKING_ID",
			"value": "",
			"type": "string"
		}
	]
}