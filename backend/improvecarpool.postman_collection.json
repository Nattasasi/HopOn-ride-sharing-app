						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"start_location_name\": \"Grand Central\",\n    \"start_lat\": 40.7527,\n    \"start_lng\": -73.9772,\n    \"end_location_name\": \"JFK Airport\",\n    \"end_lat\": 40.6413,\n    \"end_lng\": -73.7781,\n    \"departure_time\": \"2026-05-01T10:00:00Z\",\n    \"total_seats\": 3,\n    \"price_per_seat\": 25.0\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/v1/posts",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"posts"
							]
						}
					}
				},
				{
					"name": "Get All Available Rides",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/v1/posts",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"posts"
							]
						}
					}
				},
				{
					"name": "Get My Created Rides",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/v1/posts/me",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"posts",
								"me"
							]
						}
					}
				}
			]
		},
		{
			"name": "Bookings & Joining",
			"item": [
				{
					"name": "Request to Join Ride",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"post_id\": \"PASTE_POST_ID_HERE\",\n    \"seats_booked\": 1\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/v1/bookings",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"bookings"
							]
						}
					}
				},
				{
					"name": "Respond to Booking (Driver)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"accepted\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/v1/bookings/{{BOOKING_ID}}/respond",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"bookings",
								"{{BOOKING_ID}}",
								"respond"
							]
						}
					}
				},
				{
					"name": "Get My Bookings (Passenger)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/v1/bookings/me",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"bookings",
								"me"
							]
						}
					}
				},
				{
					"name": "Get Bookings for a Ride (Driver)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/v1/bookings/posts/{{POST_ID}}",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"bookings",
								"posts",
								"{{POST_ID}}"
							]
						}
					}
				},
				{
					"name": "Cancel Booking",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/v1/bookings/{{BOOKING_ID}}/cancel",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"v1",
								"bookings",
								"{{BOOKING_ID}}",
								"cancel"
							]
						}
					}
				}
			]
		}
	],
